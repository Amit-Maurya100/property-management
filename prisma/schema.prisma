generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccountStatus {
  ACTIVE
  LOCKED
  DISABLED
  EXPIRED

  @@map("account_status")
}

enum AttemptType {
  SUCCESS
  FAILURE
  LOCKED

  @@map("attempt_type")
}

model User {
  id                  BigInt        @id @default(autoincrement())
  uuid                String        @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username            String        @unique @db.VarChar(100)
  email               String        @unique @db.VarChar(255)
  passwordHash        String        @map("password_hash") @db.VarChar(255)
  loginAttempts       Int           @default(0) @map("login_attempts")
  lastLoginAttempt    DateTime?     @map("last_login_attempt") @db.Timestamptz
  lastSuccessfulLogin DateTime?     @map("last_successful_login") @db.Timestamptz
  lockedUntil         DateTime?     @map("locked_until") @db.Timestamptz
  isLocked            Boolean       @default(false) @map("is_locked")
  accountStatus       AccountStatus @default(ACTIVE) @map("account_status")
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  userRoles    UserRole[]   @relation("UserRoles")
  grantedRoles UserRole[]   @relation("GrantedBy")
  loginAudits  LoginAudit[]
  properties   Property[]   @relation("PropertyOwner")
  tenants      Tenant[]     @relation("TenantOwner")
  organizations Organization?

  @@index([username], map: "idx_users_username")
  @@index([email], map: "idx_users_email")
  @@index([accountStatus, isLocked], map: "idx_users_account_status")
  @@index([lockedUntil], map: "idx_users_locked_until")
  @@map("users")
}

model Role {
  id          BigInt   @id @default(autoincrement())
  uuid        String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Resource {
  id          BigInt   @id @default(autoincrement())
  uuid        String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  permissions Permission[]

  @@index([name], map: "idx_resources_name")
  @@index([isActive], map: "idx_resources_active")
  @@map("resources")
}

model Action {
  id          BigInt   @id @default(autoincrement())
  uuid        String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique @db.VarChar(50)
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  permissions Permission[]

  @@index([name], map: "idx_actions_name")
  @@index([isActive], map: "idx_actions_active")
  @@map("actions")
}

model Permission {
  id          BigInt   @id @default(autoincrement())
  uuid        String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resourceId  BigInt   @map("resource_id")
  actionId    BigInt   @map("action_id")
  resource    String   @db.VarChar(100)
  action      String   @db.VarChar(50)
  name        String   @db.VarChar(150)
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  resourceRef     Resource         @relation(fields: [resourceId], references: [id], onDelete: Restrict)
  actionRef       Action           @relation(fields: [actionId], references: [id], onDelete: Restrict)
  rolePermissions RolePermission[]
  policies        Policy[]

  @@unique([resourceId, actionId], map: "unique_permission_resource_action")
  @@unique([resource, action], map: "unique_resource_action")
  @@index([resourceId], map: "idx_permissions_resource_id")
  @@index([actionId], map: "idx_permissions_action_id")
  @@index([resource], map: "idx_permissions_resource")
  @@index([action], map: "idx_permissions_action")
  @@index([name], map: "idx_permissions_name")
  @@map("permissions")
}

model RolePermission {
  roleId       BigInt   @map("role_id")
  permissionId BigInt   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId], map: "idx_role_permissions_role_id")
  @@index([permissionId], map: "idx_role_permissions_permission_id")
  @@map("role_permissions")
}

model UserRole {
  id        BigInt    @id @default(autoincrement())
  uuid      String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    BigInt    @map("user_id")
  roleId    BigInt    @map("role_id")
  grantedBy BigInt?   @map("granted_by")
  grantedAt DateTime  @default(now()) @map("granted_at") @db.Timestamptz
  expiresAt DateTime? @map("expires_at") @db.Timestamptz
  isActive  Boolean   @default(true) @map("is_active")

  user    User            @relation("UserRoles", fields: [userId], references: [id], onDelete: Cascade)
  role    Role            @relation(fields: [roleId], references: [id], onDelete: Cascade)
  granter User?           @relation("GrantedBy", fields: [grantedBy], references: [id], onDelete: SetNull)
  scopes  UserRoleScope[]

  @@unique([userId, roleId], map: "unique_user_role")
  @@index([userId], map: "idx_user_roles_user_id")
  @@index([roleId], map: "idx_user_roles_role_id")
  @@index([grantedBy], map: "idx_user_roles_granted_by")
  @@index([expiresAt], map: "idx_user_roles_expires_at")
  @@index([isActive], map: "idx_user_roles_active")
  @@map("user_roles")
}

model UserRoleScope {
  id         BigInt   @id @default(autoincrement())
  uuid       String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userRoleId BigInt   @map("user_role_id")
  scopeType  String   @map("scope_type") @db.VarChar(50)
  scopeValue String   @map("scope_value") @db.VarChar(255)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  userRole UserRole @relation(fields: [userRoleId], references: [id], onDelete: Cascade)

  @@unique([userRoleId, scopeType, scopeValue], map: "unique_user_role_scope")
  @@index([userRoleId], map: "idx_user_role_scopes_user_role_id")
  @@index([scopeType, scopeValue], map: "idx_user_role_scopes_lookup")
  @@map("user_role_scopes")
}

model Policy {
  id           BigInt   @id @default(autoincrement())
  uuid         String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  permissionId BigInt   @map("permission_id")
  condition    Json
  priority     Int      @default(0)
  isActive     Boolean  @default(true) @map("is_active")
  description  String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@index([permissionId], map: "idx_policies_permission_id")
  @@index([priority(sort: Desc)], map: "idx_policies_priority")
  @@map("policies")
}

model LoginAudit {
  id            BigInt      @id @default(autoincrement())
  uuid          String      @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        BigInt?     @map("user_id")
  email         String?     @db.VarChar(255)
  ipAddress     String?     @map("ip_address")
  userAgent     String?     @map("user_agent")
  attemptType   AttemptType @map("attempt_type")
  attemptTime   DateTime    @default(now()) @map("attempt_time") @db.Timestamptz
  failureReason String?     @map("failure_reason")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_login_audit_user_id")
  @@index([attemptTime(sort: Desc)], map: "idx_login_audit_attempt_time")
  @@index([ipAddress], map: "idx_login_audit_ip")
  @@map("login_audit")
}

enum PropertyType {
  APARTMENT
  HOTEL
  HOSTEL
  OFFICE

  @@map("property_type")
}

enum UnitType {
  APARTMENT
  ROOM
  OFFICE
  SHOP
  HALL

  @@map("unit_type")
}

enum RoomType {
  BEDROOM
  KITCHEN
  BATHROOM
  OFFICE_ROOM

  @@map("room_type")
}

enum BedType {
  SINGLE
  DOUBLE
  BUNK

  @@map("bed_type")
}

enum AmenityCategory {
  INTERNET
  PARKING
  SECURITY

  @@map("amenity_category")
}

enum BillingCycle {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY

  @@map("billing_cycle")
}

enum AvailabilityStatus {
  AVAILABLE
  RESERVED
  OCCUPIED

  @@map("availability_status")
}

enum PaymentMode {
  CASH
  CHEQUE
  NEFT
  UPI
  OTHER

  @@map("payment_mode")
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID

  @@map("payment_status")
}

model Address {
  id        BigInt   @id @default(autoincrement())
  uuid      String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  line1     String   @map("line1") @db.VarChar(255)
  line2     String?  @map("line2") @db.VarChar(255)
  city      String   @db.VarChar(100)
  state     String?  @db.VarChar(100)
  country   String   @db.VarChar(100)
  zipcode   String?  @db.VarChar(20)
  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  property Property?
  organization Organization?

  @@map("addresses")
}

model Property {
  id           BigInt       @id @default(autoincrement())
  uuid         String       @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String       @db.VarChar(255)
  description  String?
  propertyType PropertyType @map("property_type")
  ownerId      BigInt       @map("owner_id")
  addressId    BigInt       @unique @map("address_id")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  owner    User              @relation("PropertyOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  address  Address           @relation(fields: [addressId], references: [id], onDelete: Restrict)
  buildings Building[]
  images   PropertyImage[]
  amenities PropertyAmenity[]

  @@index([ownerId], map: "idx_properties_owner_id")
  @@index([propertyType], map: "idx_properties_type")
  @@map("properties")
}

model PropertyImage {
  id         BigInt   @id @default(autoincrement())
  uuid       String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  propertyId BigInt   @map("property_id")
  url        String   @db.VarChar(500)
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId], map: "idx_property_images_property_id")
  @@map("property_images")
}

model Amenity {
  id          BigInt          @id @default(autoincrement())
  uuid        String          @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String          @unique @db.VarChar(100)
  category    AmenityCategory
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  properties PropertyAmenity[]

  @@index([category], map: "idx_amenities_category")
  @@map("amenities")
}

model PropertyAmenity {
  propertyId BigInt   @map("property_id")
  amenityId  BigInt   @map("amenity_id")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amenity  Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([propertyId, amenityId])
  @@map("property_amenities")
}

model Building {
  id         BigInt   @id @default(autoincrement())
  uuid       String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  propertyId BigInt   @map("property_id")
  name       String   @db.VarChar(255)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  floors   Floor[]
  utilityRates BuildingUtilityRate[]

  @@index([propertyId], map: "idx_buildings_property_id")
  @@map("buildings")
}

enum BuildingUtilityType {
  ELECTRICITY
  GAS
  CLEANING

  @@map("building_utility_type")
}

model BuildingUtilityRate {
  id           BigInt              @id @default(autoincrement())
  uuid         String              @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  buildingId   BigInt              @map("building_id")
  utilityType  BuildingUtilityType @map("utility_type")
  unitRate     Decimal             @map("unit_rate") @db.Decimal(12, 2)
  startDate    DateTime            @map("start_date") @db.Date
  endDate      DateTime            @map("end_date") @db.Date
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([buildingId, utilityType, startDate, endDate], map: "idx_building_utility_rates_lookup")
  @@map("building_utility_rates")
}

model Floor {
  id          BigInt   @id @default(autoincrement())
  uuid        String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  buildingId  BigInt   @map("building_id")
  floorNumber Int      @map("floor_number")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  units    Unit[]

  @@unique([buildingId, floorNumber], map: "unique_building_floor_number")
  @@index([buildingId], map: "idx_floors_building_id")
  @@map("floors")
}

model Unit {
  id         BigInt   @id @default(autoincrement())
  uuid       String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  floorId    BigInt   @map("floor_id")
  unitNumber String   @map("unit_number") @db.VarChar(50)
  unitType   UnitType @map("unit_type")
  capacity   Int?
  area       Decimal? @db.Decimal(10, 2)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  floor          Floor          @relation(fields: [floorId], references: [id], onDelete: Cascade)
  rooms          Room[]
  pricingRecords Pricing[]
  availabilities Availability[]
  rents          Rent[]
  tenants        Tenant[]
  tenantAssignments TenantAssignment[]

  @@unique([floorId, unitNumber], map: "unique_floor_unit_number")
  @@index([floorId], map: "idx_units_floor_id")
  @@map("units")
}

model Room {
  id       BigInt   @id @default(autoincrement())
  uuid     String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  unitId   BigInt   @map("unit_id")
  name     String   @db.VarChar(100)
  roomType RoomType @map("room_type")
  area     Decimal? @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  unit Unit  @relation(fields: [unitId], references: [id], onDelete: Cascade)
  beds Bed[]

  @@index([unitId], map: "idx_rooms_unit_id")
  @@map("rooms")
}

model Bed {
  id        BigInt   @id @default(autoincrement())
  uuid      String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomId    BigInt   @map("room_id")
  bedType   BedType  @map("bed_type")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId], map: "idx_beds_room_id")
  @@map("beds")
}

model Pricing {
  id              BigInt       @id @default(autoincrement())
  uuid            String       @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  unitId          BigInt       @map("unit_id")
  currency        String       @db.VarChar(3)
  basePrice       Decimal      @map("base_price") @db.Decimal(12, 2)
  billingCycle    BillingCycle @map("billing_cycle")
  securityDeposit Decimal?     @map("security_deposit") @db.Decimal(12, 2)
  effectiveFrom   DateTime     @default(now()) @map("effective_from") @db.Timestamptz
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId], map: "idx_pricing_unit_id")
  @@index([effectiveFrom(sort: Desc)], map: "idx_pricing_effective_from")
  @@map("pricing")
}

model Availability {
  id            BigInt             @id @default(autoincrement())
  uuid          String             @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  unitId        BigInt             @map("unit_id")
  availableFrom DateTime?          @map("available_from") @db.Timestamptz
  availableTo   DateTime?          @map("available_to") @db.Timestamptz
  status        AvailabilityStatus
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId], map: "idx_availability_unit_id")
  @@index([status], map: "idx_availability_status")
  @@map("availability")
}

model Tenant {
  id         BigInt   @id @default(autoincrement())
  uuid       String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId    BigInt   @map("owner_id")
  unitId     BigInt?  @map("unit_id")
  firstName  String   @map("first_name") @db.VarChar(100)
  lastName   String   @map("last_name") @db.VarChar(100)
  email      String?  @db.VarChar(255)
  phone      String?  @db.VarChar(30)
  idDocument String?  @map("id_document") @db.VarChar(100)
  pictureUrl String?  @map("picture_url") @db.VarChar(2048)
  advanceBalance Decimal @default(0) @map("advance_balance") @db.Decimal(12, 2)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  owner        User               @relation("TenantOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  unit         Unit?              @relation(fields: [unitId], references: [id], onDelete: SetNull)
  assignments  TenantAssignment[]
  rents        Rent[]
  payments     Payment[]

  @@index([ownerId], map: "idx_tenants_owner_id")
  @@index([unitId], map: "idx_tenants_unit_id")
  @@index([email], map: "idx_tenants_email")
  @@map("tenants")
}

model TenantAssignment {
  id                      BigInt    @id @default(autoincrement())
  uuid                    String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                BigInt    @map("tenant_id")
  unitId                  BigInt    @map("unit_id")
  monthlyRent             Decimal?  @map("monthly_rent") @db.Decimal(12, 2)
  leaseFrom               DateTime? @map("lease_from") @db.Date
  leaseTo                 DateTime? @map("lease_to") @db.Date
  monthlyDueDay           Int?      @map("monthly_due_day")
  initialGasUnits         Decimal?  @map("initial_gas_units") @db.Decimal(10, 2)
  initialElectricityUnits Decimal?  @map("initial_electricity_units") @db.Decimal(10, 2)
  isActive                Boolean   @default(true) @map("is_active")
  notes                   String?
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Restrict)
  rents  Rent[]

  @@index([tenantId], map: "idx_tenant_assignments_tenant_id")
  @@index([unitId], map: "idx_tenant_assignments_unit_id")
  @@index([isActive], map: "idx_tenant_assignments_is_active")
  @@map("tenant_assignments")
}

model Rent {
  id                  BigInt    @id @default(autoincrement())
  uuid                String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            BigInt    @map("tenant_id")
  tenantAssignmentId  BigInt    @map("tenant_assignment_id")
  unitId              BigInt    @map("unit_id")
  startDate           DateTime  @map("start_date") @db.Date
  endDate             DateTime? @map("end_date") @db.Date
  rent                Decimal   @db.Decimal(12, 2)
  totalRent           Decimal?  @map("total_rent") @db.Decimal(12, 2)
  electricityUnits    Decimal?  @map("electricity_units") @db.Decimal(10, 2)
  gasUnits            Decimal?  @map("gas_units") @db.Decimal(10, 2)
  maintenance         Decimal?  @db.Decimal(12, 2)
  misc                Decimal?  @db.Decimal(12, 2)
  dueDate             DateTime      @map("due_date") @db.Date
  utilityBaseline     Json?         @map("utility_baseline")
  utilityRateSnapshot Json?         @map("utility_rate_snapshot")
  priorBalance        Decimal       @default(0) @map("prior_balance") @db.Decimal(12, 2)
  balanceCarriedForward Boolean     @default(false) @map("balance_carried_forward")
  paymentStatus       PaymentStatus @default(PENDING) @map("payment_status")
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  tenantAssignment TenantAssignment @relation(fields: [tenantAssignmentId], references: [id], onDelete: Restrict)
  unit             Unit             @relation(fields: [unitId], references: [id], onDelete: Restrict)
  payments         Payment[]

  @@index([tenantId], map: "idx_rents_tenant_id")
  @@index([tenantAssignmentId], map: "idx_rents_tenant_assignment_id")
  @@index([unitId], map: "idx_rents_unit_id")
  @@index([dueDate], map: "idx_rents_due_date")
  @@index([paymentStatus], map: "idx_rents_payment_status")
  @@map("rents")
}

model Payment {
  id            BigInt      @id @default(autoincrement())
  uuid          String      @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rentId        BigInt      @map("rent_id")
  tenantId      BigInt      @map("tenant_id")
  amount        Decimal     @db.Decimal(12, 2)
  mode          PaymentMode
  appliedToRent Decimal     @map("applied_to_rent") @db.Decimal(12, 2)
  toAdvance     Decimal     @default(0) @map("to_advance") @db.Decimal(12, 2)
  paidAt        DateTime    @default(now()) @map("paid_at") @db.Date
  notes         String?
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  rent   Rent   @relation(fields: [rentId], references: [id], onDelete: Restrict)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([rentId], map: "idx_payments_rent_id")
  @@index([tenantId], map: "idx_payments_tenant_id")
  @@index([paidAt], map: "idx_payments_paid_at")
  @@map("payments")
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED

  @@map("organization_status")
}

enum GstInvoiceType {
  B2B_SALE
  B2C_SALE
  PURCHASE

  @@map("gst_invoice_type")
}

model Organization {
  id               BigInt             @id @default(autoincrement())
  uuid             String             @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId          BigInt             @unique @map("owner_id")
  name             String             @db.VarChar(255)
  addressId        BigInt             @unique @map("address_id")
  gstNumber        String             @map("gst_number") @db.VarChar(15)
  ownerName        String             @map("owner_name") @db.VarChar(255)
  registrationDate DateTime           @map("registration_date") @db.Date
  currentStatus    OrganizationStatus @default(ACTIVE) @map("current_status")
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  owner    User         @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  address  Address      @relation(fields: [addressId], references: [id], onDelete: Restrict)
  invoices GstInvoice[]
  taxConfigurations GstTaxConfiguration[]
  gstMasters GstMaster[]

  @@index([gstNumber], map: "idx_organizations_gst_number")
  @@map("organizations")
}

model GstTaxConfiguration {
  id             BigInt   @id @default(autoincrement())
  uuid           String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId BigInt   @map("organization_id")
  cgstRate       Decimal  @map("cgst_rate") @db.Decimal(5, 2)
  sgstRate       Decimal  @map("sgst_rate") @db.Decimal(5, 2)
  igstRate       Decimal  @map("igst_rate") @db.Decimal(5, 2)
  startDate      DateTime @map("start_date") @db.Date
  endDate        DateTime @map("end_date") @db.Date
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, startDate, endDate], map: "idx_gst_tax_config_org_dates")
  @@map("gst_tax_configurations")
}

model GstInvoice {
  id              BigInt         @id @default(autoincrement())
  uuid            String         @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  BigInt         @map("organization_id")
  invoiceType     GstInvoiceType @map("invoice_type")
  invoiceNumber   String         @map("invoice_number") @db.VarChar(100)
  invoiceDate     DateTime       @map("invoice_date") @db.Date
  gstNumber       String?        @map("gst_number") @db.VarChar(15)
  tradeName       String?        @map("trade_name") @db.VarChar(255)
  customerName    String?        @map("customer_name") @db.VarChar(255)
  customerAddress String?        @map("customer_address")
  taxableValue    Decimal        @map("taxable_value") @db.Decimal(12, 2)
  cgst            Decimal        @default(0) @db.Decimal(12, 2)
  sgst            Decimal        @default(0) @db.Decimal(12, 2)
  igst            Decimal        @default(0) @db.Decimal(12, 2)
  cess            Decimal        @default(0) @db.Decimal(12, 2)
  totalTaxAmount  Decimal        @map("total_tax_amount") @db.Decimal(12, 2)
  invoiceValue    Decimal        @map("invoice_value") @db.Decimal(12, 2)
  description     String?
  paymentStatus   PaymentStatus  @default(PENDING) @map("payment_status")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, invoiceType, invoiceNumber], map: "unique_org_type_invoice_number")
  @@index([organizationId, invoiceType], map: "idx_gst_invoices_org_type")
  @@index([invoiceDate], map: "idx_gst_invoices_date")
  @@map("gst_invoices")
}

model GstMaster {
  id                        BigInt   @id @default(autoincrement())
  uuid                      String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId            BigInt   @map("organization_id")
  gstNumber                 String   @map("gst_number") @db.VarChar(15)
  legalName                 String   @map("legal_name") @db.VarChar(255)
  tradeName                 String   @map("trade_name") @db.VarChar(255)
  effectiveRegistrationDate DateTime @map("effective_registration_date") @db.Date
  constitutionOfBusiness    String   @map("constitution_of_business") @db.VarChar(100)
  gstinStatus               String   @map("gstin_status") @db.VarChar(50)
  taxpayerType              String   @map("taxpayer_type") @db.VarChar(50)
  principalPlaceOfBusiness  String   @map("principal_place_of_business")
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, gstNumber], map: "unique_org_gst_master_number")
  @@index([organizationId], map: "idx_gst_masters_org")
  @@index([gstNumber], map: "idx_gst_masters_gst_number")
  @@map("gst_masters")
}
